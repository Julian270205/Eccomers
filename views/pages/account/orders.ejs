<% layout = 'layouts/main' %>
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-10 gap-4">
    <div>
      <h1 class="font-serif text-3xl font-bold">Mi Cuenta</h1>
      <p class="text-gray-500 mt-1"><%= user.name %> · <%= user.email %></p>
    </div>
    <div class="bg-boutique-pink px-6 py-4 text-center">
      <p class="text-2xl font-bold"><%= user.loyaltyPoints %></p>
      <p class="text-sm font-medium">puntos acumulados</p>
    </div>
  </div>

  <h2 class="font-semibold text-xl mb-6">Historial de pedidos</h2>
  <% if (orders.length === 0) { %>
    <div class="text-center py-16 border border-dashed border-gray-300">
      <p class="text-gray-500">Aún no has realizado pedidos</p>
      <a href="/productos" class="mt-4 inline-block bg-black text-white px-8 py-3 font-medium hover:bg-gray-800 transition-colors">Ir al catálogo</a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% orders.forEach(order => { %>
        <div class="bg-white border border-gray-200 p-6">
          <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
            <div>
              <p class="font-semibold">Pedido #<%= order.id %></p>
              <p class="text-sm text-gray-500"><%= formatDate(order.createdAt) %></p>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-sm px-3 py-1 rounded-full
                <%= order.status === 'delivered' ? 'bg-green-100 text-green-800' :
                   order.status === 'confirmed' ? 'bg-blue-100 text-blue-800' :
                   order.status === 'pending_whatsapp_confirmation' ? 'bg-yellow-100 text-yellow-800' :
                   'bg-gray-100 text-gray-800' %>">
                <%= order.status === 'pending_whatsapp_confirmation' ? 'Pendiente confirmación' :
                   order.status === 'confirmed' ? 'Confirmado' :
                   order.status === 'processing' ? 'En proceso' :
                   order.status === 'shipped' ? 'Enviado' :
                   order.status === 'delivered' ? 'Entregado' :
                   order.status === 'cancelled' ? 'Cancelado' : order.status %>
              </span>
              <span class="font-semibold"><%= formatCurrency(parseFloat(order.total)) %></span>
            </div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <% order.items.forEach(item => { %>
              <div class="flex items-center gap-2">
                <img src="<%= item.product?.imageUrl || 'https://images.unsplash.com/photo-1434389677669-e08b4cac3105?w=50&q=80' %>" class="w-12 h-14 object-cover" alt="">
                <div class="text-xs">
                  <p class="font-medium leading-tight"><%= item.productName %></p>
                  <p class="text-gray-500">T: <%= item.size %> · x<%= item.quantity %></p>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Loyalty ledger -->
  <% if (ledger && ledger.length > 0) { %>
    <h2 class="font-semibold text-xl mt-12 mb-6">Historial de puntos</h2>
    <div class="bg-white border border-gray-200 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Fecha</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Descripción</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase">Puntos</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% ledger.forEach(entry => { %>
            <tr>
              <td class="px-4 py-3 text-gray-500"><%= formatDate(entry.createdAt, 'DD/MM/YY') %></td>
              <td class="px-4 py-3"><%= entry.description %></td>
              <td class="px-4 py-3 text-right font-semibold <%= entry.points > 0 ? 'text-green-600' : 'text-red-500' %>">
                <%= entry.points > 0 ? '+' : '' %><%= entry.points %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
