<% layout = 'layouts/main' %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="font-serif text-4xl font-bold">Catálogo</h1>
    <p class="text-gray-500 mt-2"><%= total %> producto<%= total !== 1 ? 's' : '' %> encontrado<%= total !== 1 ? 's' : '' %></p>
  </div>

  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Filters Sidebar -->
    <aside class="w-full lg:w-64 flex-shrink-0">
      <form id="filter-form" method="GET" action="/productos">
        <div class="bg-white border border-gray-200 p-6 space-y-6">
          <!-- Search -->
          <div>
            <label class="block text-xs font-semibold tracking-widest uppercase text-gray-700 mb-3">Buscar</label>
            <input type="text" name="q" value="<%= filters.search || '' %>" placeholder="Nombre de prenda..." class="w-full border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-black">
          </div>
          <!-- Category -->
          <div>
            <label class="block text-xs font-semibold tracking-widest uppercase text-gray-700 mb-3">Categoría</label>
            <div class="space-y-2">
              <label class="flex items-center gap-2 text-sm cursor-pointer">
                <input type="radio" name="category" value="" <%= !filters.category ? 'checked' : '' %> class="text-black"> Todas
              </label>
              <%
                const catLabel = { Camisa:'Camisas', Blusa:'Blusas', Vestido:'Vestidos', Falda:'Faldas',
                                   Shorts:'Shorts', Pantalones:'Pantalones', Jeans:'Jeans', Enterizos:'Enterizos' };
              %>
              <% CATEGORIES.forEach(cat => { %>
                <label class="flex items-center gap-2 text-sm cursor-pointer">
                  <input type="radio" name="category" value="<%= cat %>" <%= filters.category === cat ? 'checked' : '' %> class="text-black"> <%= catLabel[cat] || cat %>
                </label>
              <% }) %>
            </div>
          </div>
          <!-- Size -->
          <div>
            <label class="block text-xs font-semibold tracking-widest uppercase text-gray-700 mb-3">Talla</label>
            <div class="flex flex-wrap gap-2">
              <% SIZES.forEach(size => { %>
                <label class="cursor-pointer">
                  <input type="radio" name="size" value="<%= size %>" <%= filters.size === size ? 'checked' : '' %> class="sr-only peer">
                  <span class="peer-checked:bg-black peer-checked:text-white border border-gray-300 px-3 py-1 text-xs font-medium hover:border-black transition-colors block"><%= size %></span>
                </label>
              <% }) %>
            </div>
          </div>
          <!-- Price Range -->
          <div>
            <label class="block text-xs font-semibold tracking-widest uppercase text-gray-700 mb-3">Precio</label>
            <div class="flex gap-2">
              <input type="number" name="minPrice" value="<%= filters.minPrice || '' %>" placeholder="Mín" class="w-1/2 border border-gray-300 px-2 py-2 text-sm focus:outline-none focus:border-black">
              <input type="number" name="maxPrice" value="<%= filters.maxPrice || '' %>" placeholder="Máx" class="w-1/2 border border-gray-300 px-2 py-2 text-sm focus:outline-none focus:border-black">
            </div>
          </div>
          <!-- Sort -->
          <div>
            <label class="block text-xs font-semibold tracking-widest uppercase text-gray-700 mb-3">Ordenar por</label>
            <select name="sort" class="w-full border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-black">
              <option value="" <%= !filters.sort ? 'selected' : '' %>>Más recientes</option>
              <option value="price_asc" <%= filters.sort === 'price_asc' ? 'selected' : '' %>>Precio: menor a mayor</option>
              <option value="price_desc" <%= filters.sort === 'price_desc' ? 'selected' : '' %>>Precio: mayor a menor</option>
              <option value="best_sellers" <%= filters.sort === 'best_sellers' ? 'selected' : '' %>>Más vendidos</option>
              <option value="featured" <%= filters.sort === 'featured' ? 'selected' : '' %>>Destacados</option>
            </select>
          </div>
          <button type="submit" class="w-full bg-black text-white py-3 text-sm font-medium hover:bg-gray-800 transition-colors">Aplicar filtros</button>
          <a href="/productos" class="block w-full text-center text-sm text-gray-500 hover:text-black py-2">Limpiar filtros</a>
        </div>
      </form>
    </aside>

    <!-- Products Grid -->
    <div class="flex-1">
      <% if (products.length === 0) { %>
        <div class="text-center py-20">
          <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <p class="text-gray-500 text-lg">No encontramos productos con esos filtros</p>
          <a href="/productos" class="mt-4 inline-block text-sm underline text-gray-600 hover:text-black">Ver todos los productos</a>
        </div>
      <% } else { %>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-6">
          <% products.forEach(product => { %>
            <a href="/productos/<%= product.slug %>" class="group bg-white border border-transparent hover:border-gray-200 transition-colors">
              <div class="relative overflow-hidden aspect-[3/4] bg-gray-100">
                <% const totalStock = product.variants.reduce((a,v) => a+v.stock, 0) %>
                <% if (totalStock === 0) { %>
                  <span class="absolute top-3 left-3 bg-gray-900 text-white text-xs font-bold px-2 py-1 z-10">AGOTADO</span>
                <% } else if (product.priceInfo.hasDiscount) { %>
                  <span class="absolute top-3 left-3 bg-boutique-pink text-black text-xs font-bold px-2 py-1 z-10">OFERTA</span>
                <% } %>
                <img src="<%= product.imageUrl || 'https://images.unsplash.com/photo-1434389677669-e08b4cac3105?w=300&q=80' %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                <button class="absolute bottom-0 inset-x-0 bg-black text-white py-3 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity add-to-cart-btn"
                  data-product-id="<%= product.id %>"
                  data-product-slug="<%= product.slug %>"
                  onclick="event.preventDefault(); openProductSizeModal('<%= product.slug %>')">
                  Seleccionar talla
                </button>
              </div>
              <div class="p-4">
                <p class="text-xs text-gray-400 tracking-wide uppercase mb-1"><%= product.category %></p>
                <h3 class="font-medium text-gray-900 text-sm leading-tight mb-2"><%= product.name %></h3>
                <div class="flex items-center gap-2">
                  <span class="font-semibold text-sm"><%= formatCurrency(product.priceInfo.finalPrice) %></span>
                  <% if (product.priceInfo.hasDiscount) { %>
                    <span class="text-xs text-gray-400 line-through"><%= formatCurrency(product.priceInfo.originalPrice) %></span>
                  <% } %>
                </div>
                <!-- Available sizes -->
                <div class="flex gap-1 mt-2">
                  <% product.variants.forEach(v => { %>
                    <span class="text-xs border px-1.5 py-0.5 <%= v.stock > 0 ? 'border-gray-300 text-gray-600' : 'border-gray-100 text-gray-300 line-through' %>"><%= v.size %></span>
                  <% }) %>
                </div>
              </div>
            </a>
          <% }) %>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
          <div class="flex justify-center gap-2 mt-12">
            <% for (let p = 1; p <= totalPages; p++) { %>
              <a href="?<%= Object.entries(filters).filter(([k,v])=>v).map(([k,v])=>`${k}=${v}`).join('&') %>&page=<%= p %>"
                class="w-10 h-10 flex items-center justify-center text-sm border <%= currentPage === p ? 'bg-black text-white border-black' : 'border-gray-300 hover:border-black' %> transition-colors">
                <%= p %>
              </a>
            <% } %>
          </div>
        <% } %>
      <% } %>
    </div>
  </div>
</div>

<script>
function openProductSizeModal(slug) { window.location.href = '/productos/' + slug; }
</script>
