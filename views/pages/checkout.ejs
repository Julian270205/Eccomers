<% layout = 'layouts/main' %>
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12" x-data="checkoutApp()">
  <h1 class="font-serif text-4xl font-bold mb-10">Checkout</h1>
  <form action="/checkout/place-order" method="POST">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      <!-- Shipping form -->
      <div class="space-y-6">
        <h2 class="font-semibold text-xl">Datos de envío</h2>
        <div>
          <label class="block text-sm font-medium mb-2">Nombre completo *</label>
          <input type="text" name="name" value="<%= user.name %>" required class="w-full border border-gray-300 px-4 py-3 focus:outline-none focus:border-black">
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">Correo electrónico *</label>
          <input type="email" name="email" value="<%= user.email %>" required class="w-full border border-gray-300 px-4 py-3 focus:outline-none focus:border-black">
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">Teléfono *</label>
          <input type="tel" name="phone" value="<%= user.phone || '' %>" required class="w-full border border-gray-300 px-4 py-3 focus:outline-none focus:border-black" placeholder="300 123 4567">
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">Ciudad *</label>
          <input type="text" name="city" id="city-input" required class="w-full border border-gray-300 px-4 py-3 focus:outline-none focus:border-black" placeholder="Cali" @input="checkCity($event.target.value)">
          <p class="text-xs text-gray-500 mt-1">Contraentrega disponible solo en Cali, Colombia</p>
          <p x-show="!isCali && cityEntered" class="text-xs text-amber-600 mt-1">⚠️ El envío fuera de Cali se coordina por WhatsApp</p>
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">Dirección *</label>
          <input type="text" name="address" required class="w-full border border-gray-300 px-4 py-3 focus:outline-none focus:border-black" placeholder="Calle 15 # 20-30, Barrio Centro">
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">Notas adicionales</label>
          <textarea name="notes" rows="3" class="w-full border border-gray-300 px-4 py-3 focus:outline-none focus:border-black resize-none" placeholder="Instrucciones especiales de entrega..."></textarea>
        </div>

        <!-- Método de pago -->
        <div class="bg-green-50 border border-green-200 p-5">
          <div class="flex items-center gap-3">
            <svg class="w-8 h-8 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.464 3.488"/></svg>
            <div>
              <p class="font-semibold text-green-800">Pago por WhatsApp / Contraentrega</p>
              <p class="text-sm text-green-700 mt-0.5">Confirmaremos tu pedido y coordinaremos el pago directamente contigo.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Order summary -->
      <div>
        <div class="bg-gray-50 border border-gray-200 p-6 sticky top-24">
          <h2 class="font-semibold text-xl mb-6">Tu pedido</h2>
          <div class="space-y-4">
            <% cart.items.forEach(item => { %>
              <div class="flex gap-4">
                <img src="<%= item.product?.imageUrl || 'https://images.unsplash.com/photo-1434389677669-e08b4cac3105?w=60&q=80' %>" class="w-14 h-18 object-cover flex-shrink-0 border border-gray-200" alt="">
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium leading-tight"><%= item.product.name %></p>
                  <p class="text-xs text-gray-500">Talla: <%= item.variant.size %> · x<%= item.quantity %></p>
                </div>
                <p class="text-sm font-semibold flex-shrink-0"><%= formatCurrency(item.effectivePrice * item.quantity) %></p>
              </div>
            <% }) %>
          </div>

          <!-- Coupon -->
          <div class="border-t border-gray-200 mt-6 pt-6">
            <label class="block text-sm font-medium mb-2">Cupón de descuento</label>
            <div class="flex gap-2">
              <input type="text" id="coupon-input" placeholder="BIENVENIDA15" class="flex-1 border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-black">
              <button type="button" @click="applyCoupon()" class="bg-black text-white px-4 py-2 text-sm hover:bg-gray-800 transition-colors">Aplicar</button>
            </div>
            <input type="hidden" name="couponCode" :value="appliedCoupon">
            <p x-show="couponMsg" x-text="couponMsg" :class="couponOk ? 'text-green-600' : 'text-red-500'" class="text-xs mt-2"></p>
          </div>

          <!-- Totals -->
          <div class="border-t border-gray-200 mt-6 pt-4 space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-gray-600">Subtotal</span><span><%= formatCurrency(cart.subtotal) %></span></div>
            <div x-show="couponDiscount > 0" class="flex justify-between text-green-600"><span>Descuento</span><span>- <span x-text="formatCOP(couponDiscount)"></span></span></div>
            <div class="flex justify-between font-bold text-base border-t border-gray-300 pt-3 mt-3">
              <span>Total</span>
              <span x-text="formatCOP(<%= cart.subtotal %> - couponDiscount)"></span>
            </div>
          </div>

          <button type="submit" class="w-full bg-black text-white py-4 font-medium hover:bg-gray-800 transition-colors mt-6 text-center">
            Confirmar pedido vía WhatsApp
          </button>
          <p class="text-xs text-gray-500 text-center mt-3">Al confirmar, se abrirá WhatsApp con el resumen de tu pedido</p>
        </div>
      </div>
    </div>
  </form>
</div>

<script>
function checkoutApp() {
  return {
    isCali: false, cityEntered: false, appliedCoupon: '', couponDiscount: 0, couponMsg: '', couponOk: false,
    checkCity(val) { this.cityEntered = val.length > 0; this.isCali = val.trim().toLowerCase() === 'cali'; },
    formatCOP(amount) { return new Intl.NumberFormat('es-CO',{style:'currency',currency:'COP',minimumFractionDigits:0}).format(amount); },
    async applyCoupon() {
      const code = document.getElementById('coupon-input').value.trim();
      if (!code) return;
      const res = await fetch('/checkout/validate-coupon', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ code, subtotal: <%= cart.subtotal %> })
      });
      const data = await res.json();
      if (data.success) {
        this.couponOk = true; this.couponMsg = `✅ ${data.discount > 0 ? 'Descuento: ' + this.formatCOP(data.discount) : 'Cupón aplicado'}`;
        this.couponDiscount = data.discount; this.appliedCoupon = code;
      } else {
        this.couponOk = false; this.couponMsg = '❌ ' + data.message; this.couponDiscount = 0; this.appliedCoupon = '';
      }
    }
  }
}
</script>
