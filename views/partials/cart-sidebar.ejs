<!-- Cart Sidebar -->
<div x-show="cartOpen" class="fixed inset-0 z-40" x-cloak style="display: none;">
  <div class="absolute inset-0 bg-black bg-opacity-40" @click="cartOpen = false"></div>
</div>
<div x-show="cartOpen" class="fixed right-0 top-0 h-full w-full max-w-md bg-white shadow-xl flex flex-col z-50" x-cloak x-transition:enter="transition ease-out duration-300" x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="translate-x-0" x-transition:leave-end="translate-x-full" style="display: none;">
    <div class="flex items-center justify-between p-6 border-b">
      <h2 class="font-serif text-xl font-semibold">Mi Carrito</h2>
      <button @click="cartOpen = false" class="text-gray-400 hover:text-gray-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="flex-1 overflow-y-auto p-6" id="sidebar-cart-items">
      <p class="text-gray-500 text-sm text-center py-8">Cargando carrito...</p>
    </div>
    <div class="border-t p-6">
      <div class="flex justify-between text-sm mb-2">
        <span class="text-gray-600">Subtotal</span>
        <span class="font-semibold" id="sidebar-subtotal">$ 0</span>
      </div>
      <a href="/carrito" class="block w-full bg-black text-white text-center py-3 font-medium hover:bg-gray-800 transition-colors mt-4">Ver carrito completo</a>
      <a href="/checkout" class="block w-full bg-boutique-pink text-black text-center py-3 font-medium hover:bg-boutique-pink-dark transition-colors mt-2">Ir al checkout</a>
    </div>
  </div>
</div>
