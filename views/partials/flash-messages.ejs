<% if (success && success.length) { %>
  <div class="fixed top-20 right-4 z-50 max-w-sm" id="flash-success">
    <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded shadow-lg flex items-start gap-3">
      <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      <span class="text-sm"><%= success %></span>
    </div>
  </div>
  <script>setTimeout(()=>{const el=document.getElementById('flash-success');if(el)el.remove()},4000)</script>
<% } %>
<% if (error && error.length) { %>
  <div class="fixed top-20 right-4 z-50 max-w-sm" id="flash-error">
    <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded shadow-lg flex items-start gap-3">
      <svg class="w-5 h-5 text-red-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      <span class="text-sm"><%= error %></span>
    </div>
  </div>
  <script>setTimeout(()=>{const el=document.getElementById('flash-error');if(el)el.remove()},5000)</script>
<% } %>
<% if (info && info.length) { %>
  <div class="fixed top-20 right-4 z-50 max-w-sm">
    <div class="bg-blue-50 border border-blue-200 text-blue-800 px-4 py-3 rounded shadow-lg text-sm"><%= info %></div>
  </div>
<% } %>
