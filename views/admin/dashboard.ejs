<% layout = 'layouts/admin' %>

<!-- Page header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <p class="text-xs font-semibold tracking-widest text-gray-400 uppercase">Overview</p>
    <h1 class="font-serif text-3xl font-bold text-gray-900 mt-0.5">Executive Dashboard</h1>
  </div>
  <div class="flex items-center gap-3">
    <button class="flex items-center gap-2 px-4 py-2 border border-gray-200 bg-white text-sm text-gray-600 rounded-lg hover:border-gray-300 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      Last 30 Days
    </button>
    <a href="#" class="flex items-center gap-2 px-4 py-2 bg-gray-900 text-white text-sm rounded-lg hover:bg-gray-800 transition-colors font-medium">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Export Report
    </a>
  </div>
</div>

<!-- KPI Cards -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <!-- Daily Sales -->
  <div class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
      <div class="w-9 h-9 rounded-lg bg-pink-50 flex items-center justify-center">
        <svg class="w-5 h-5 text-boutique-rose" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <span class="text-xs font-semibold text-green-600 bg-green-50 px-2 py-0.5 rounded-full">+12%</span>
    </div>
    <p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Daily Sales</p>
    <p class="text-2xl font-bold text-gray-900 mt-1"><%= formatCurrency(stats.todayRevenue) %></p>
  </div>

  <!-- Monthly Sales -->
  <div class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
      <div class="w-9 h-9 rounded-lg bg-pink-50 flex items-center justify-center">
        <svg class="w-5 h-5 text-boutique-rose" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      </div>
      <span class="text-xs font-semibold text-green-600 bg-green-50 px-2 py-0.5 rounded-full">+8.4%</span>
    </div>
    <p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Monthly Sales</p>
    <p class="text-2xl font-bold text-gray-900 mt-1"><%= formatCurrency(stats.monthRevenue) %></p>
  </div>

  <!-- Total Orders -->
  <div class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
      <div class="w-9 h-9 rounded-lg bg-pink-50 flex items-center justify-center">
        <svg class="w-5 h-5 text-boutique-rose" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
      </div>
    </div>
    <p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Total Orders</p>
    <p class="text-2xl font-bold text-gray-900 mt-1"><%= stats.pendingCount %></p>
    <p class="text-xs text-gray-400 mt-1">Pendientes de confirmar</p>
  </div>

  <!-- Active Promotions -->
  <div class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
      <div class="w-9 h-9 rounded-lg bg-pink-50 flex items-center justify-center">
        <svg class="w-5 h-5 text-boutique-rose" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
      </div>
    </div>
    <p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Active Promotions</p>
    <p class="text-2xl font-bold text-gray-900 mt-1">4 <span class="text-base font-normal text-gray-400">Campaigns</span></p>
  </div>
</div>

<!-- Chart + Low Stock -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-5">
  <!-- Chart -->
  <div class="lg:col-span-2 bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-semibold text-gray-800">Sales Performance</h3>
      <div class="flex items-center gap-2 text-xs text-gray-400">
        <span class="w-3 h-3 rounded-sm bg-boutique-pink inline-block"></span> Gross Revenue (USD)
      </div>
    </div>
    <canvas id="dailyChart" height="130"></canvas>
  </div>

  <!-- Low Stock Alerts -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        <h3 class="font-semibold text-gray-800 text-sm">Low Stock Alerts</h3>
      </div>
      <% const criticalCount = lowStock.filter(v => v.stock === 0).length %>
      <% if (criticalCount > 0) { %>
        <span class="text-xs font-bold text-red-600 bg-red-50 px-2 py-0.5 rounded-full"><%= criticalCount %> crítico</span>
      <% } %>
    </div>
    <p class="px-5 py-2 text-xs text-gray-400 border-b border-gray-50">Critical threshold: &lt; 5 units</p>
    <div class="divide-y divide-gray-50 max-h-64 overflow-y-auto">
      <% if (lowStock.length === 0) { %>
        <p class="px-5 py-8 text-sm text-gray-400 text-center">✅ Todo el stock es suficiente</p>
      <% } else { %>
        <% lowStock.slice(0,8).forEach(v => { %>
          <div class="px-5 py-3 flex items-center justify-between">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-gray-800 truncate"><%= v.product.name %></p>
              <p class="text-xs text-gray-400"><%= v.product.category %> / <span class="uppercase"><%= v.size %></span></p>
            </div>
            <span class="ml-3 text-sm font-bold flex-shrink-0 <%= v.stock === 0 ? 'text-red-600' : 'text-amber-600' %>"><%= v.stock %> LEFT</span>
          </div>
        <% }) %>
      <% } %>
    </div>
    <div class="px-5 py-3 border-t border-gray-100">
      <a href="/admin/inventory" class="text-xs font-semibold text-gray-500 hover:text-boutique-rose uppercase tracking-wider transition-colors">Manage Inventory →</a>
    </div>
  </div>
</div>

<!-- Recent Orders -->
<div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
    <h3 class="font-semibold text-gray-800">Recent Orders</h3>
    <a href="/admin/orders" class="text-xs font-semibold text-gray-400 hover:text-boutique-rose uppercase tracking-wider transition-colors">View All Orders →</a>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50/60">
        <tr>
          <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">Order ID</th>
          <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">Customer</th>
          <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">Date</th>
          <th class="px-5 py-3 text-left text-[11px] font-semibold text-gray-400 uppercase tracking-wider">Status</th>
          <th class="px-5 py-3 text-right text-[11px] font-semibold text-gray-400 uppercase tracking-wider">Total</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% recentOrders.forEach(order => { %>
          <tr class="hover:bg-gray-50/50 transition-colors">
            <td class="px-5 py-3.5">
              <a href="/admin/orders/<%= order.id %>" class="font-semibold text-gray-800 hover:text-boutique-rose transition-colors">#JR-<%= order.id %></a>
            </td>
            <td class="px-5 py-3.5">
              <p class="font-medium text-gray-800"><%= order.shippingName %></p>
              <p class="text-xs text-gray-400"><%= order.shippingEmail %></p>
            </td>
            <td class="px-5 py-3.5 text-gray-500"><%= new Date(order.createdAt).toLocaleDateString('es-CO', {day:'2-digit',month:'short',year:'numeric'}) %></td>
            <td class="px-5 py-3.5">
              <span class="px-2.5 py-1 text-xs font-semibold rounded-full
                <%= order.status === 'delivered'   ? 'bg-green-100 text-green-700' :
                   order.status === 'confirmed'    ? 'bg-blue-100 text-blue-700' :
                   order.status === 'shipped'      ? 'bg-purple-100 text-purple-700' :
                   order.status === 'processing'   ? 'bg-indigo-100 text-indigo-700' :
                   order.status === 'cancelled'    ? 'bg-red-100 text-red-700' :
                                                     'bg-amber-100 text-amber-700' %>">
                <%= order.status === 'pending_whatsapp_confirmation' ? 'Pending WA' :
                   order.status === 'confirmed'    ? 'Confirmed' :
                   order.status === 'processing'   ? 'Processing' :
                   order.status === 'shipped'      ? 'Shipped' :
                   order.status === 'delivered'    ? 'Delivered' :
                   order.status === 'cancelled'    ? 'Cancelled' : order.status %>
              </span>
            </td>
            <td class="px-5 py-3.5 text-right font-semibold text-gray-900"><%= formatCurrency(parseFloat(order.total)) %></td>
          </tr>
        <% }) %>
        <% if (recentOrders.length === 0) { %>
          <tr><td colspan="5" class="px-5 py-10 text-center text-gray-400 text-sm">No hay pedidos recientes</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
const dailyData  = <%- JSON.stringify(last30) %>;
const monthlyData = <%- JSON.stringify(last12Months) %>;
window.__dashboardData = { dailyData, monthlyData };

// Chart override with pink style
document.addEventListener('DOMContentLoaded', () => {
  const ctx = document.getElementById('dailyChart');
  if (!ctx) return;
  new Chart(ctx, {
    type: 'line',
    data: {
      labels: dailyData.map(d => d.date),
      datasets: [{
        label: 'Ventas',
        data: dailyData.map(d => d.revenue),
        borderColor: '#C4878C',
        backgroundColor: 'rgba(232,180,184,0.15)',
        borderWidth: 2.5,
        tension: 0.4,
        pointRadius: 3,
        pointBackgroundColor: '#C4878C',
        fill: true,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        y: { grid: { color: '#f3f4f6' }, ticks: { color: '#9ca3af', font: { size: 11 } } },
        x: { grid: { display: false }, ticks: { color: '#9ca3af', font: { size: 11 } } }
      }
    }
  });
});
</script>
