<% layout = 'layouts/admin' %>
<div class="max-w-xl">
  <a href="/admin/promotions" class="text-sm text-gray-500 hover:text-black mb-6 inline-block">← Volver</a>
  <form action="/admin/promotions" method="POST" class="bg-white border border-gray-200 p-6 space-y-5">
    <div>
      <label class="block text-sm font-medium mb-2">Nombre de la promoción *</label>
      <input type="text" name="name" required class="w-full border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-black">
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Código de cupón (opcional)</label>
      <input type="text" name="code" class="w-full border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-black uppercase" placeholder="VERANO20">
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-2">Tipo de descuento *</label>
        <select name="type" required class="w-full border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-black">
          <option value="percentage">Porcentaje (%)</option>
          <option value="fixed_amount">Monto fijo (COP)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Valor *</label>
        <input type="number" name="value" min="0" step="0.01" required class="w-full border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-black">
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Monto mínimo de orden (COP)</label>
      <input type="number" name="minOrderAmount" value="0" min="0" class="w-full border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-black">
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Máximo de usos (vacío = ilimitado)</label>
      <input type="number" name="maxUses" min="1" class="w-full border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-black">
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-2">Fecha inicio *</label>
        <input type="datetime-local" name="startsAt" required class="w-full border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-black">
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Fecha fin *</label>
        <input type="datetime-local" name="endsAt" required class="w-full border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-black">
      </div>
    </div>
    <div>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" name="isActive" checked class="w-4 h-4">
        <span class="text-sm font-medium">Promoción activa</span>
      </label>
    </div>
    <button type="submit" class="w-full bg-black text-white py-3 font-medium hover:bg-gray-800 transition-colors">Crear promoción</button>
  </form>
</div>
