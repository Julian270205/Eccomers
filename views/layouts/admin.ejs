<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Jhoana Rosales Boutique</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'boutique-pink': '#E8B4B8',
            'boutique-pink-dark': '#D4949A',
            'boutique-rose': '#C4878C',
          },
          fontFamily: {
            serif: ['Playfair Display', 'serif'],
            sans: ['Inter', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    .nav-active { background: #fdf2f3; color: #b5535a; font-weight: 600; }
    .nav-active svg { color: #b5535a; }
    .nav-item:hover { background: #fdf8f8; }
  </style>
</head>
<body class="bg-gray-50 font-sans text-gray-800">

<div class="flex h-screen overflow-hidden">

  <!-- ── SIDEBAR ── -->
  <aside class="w-56 bg-white border-r border-gray-100 flex flex-col flex-shrink-0">

    <!-- Brand -->
    <div class="px-5 py-5 border-b border-gray-100">
      <p class="text-[10px] font-semibold tracking-widest text-gray-400 uppercase">Admin Panel</p>
      <p class="text-gray-900 font-semibold text-base leading-tight mt-0.5">Jhoana Rosales</p>
      <p class="text-[10px] tracking-widest text-gray-400 uppercase mt-0.5">Boutique Admin</p>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <%
        const p = locals.title || '';
        function isActive(keyword) { return p.toLowerCase().includes(keyword.toLowerCase()); }
      %>
      <a href="/admin" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gray-500 transition-colors <%= isActive('dashboard') || p === 'Dashboard' ? 'nav-active' : '' %>">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v5a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm10 0a1 1 0 011-1h4a1 1 0 011 1v2a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zm10-3a1 1 0 011-1h4a1 1 0 011 1v7a1 1 0 01-1 1h-4a1 1 0 01-1-1v-7z"/></svg>
        Dashboard
      </a>
      <a href="/admin/products" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gray-500 transition-colors <%= isActive('producto') ? 'nav-active' : '' %>">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        Products
      </a>
      <a href="/admin/inventory" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gray-500 transition-colors <%= isActive('inventario') ? 'nav-active' : '' %>">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        Inventory
      </a>
      <a href="/admin/promotions" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gray-500 transition-colors <%= isActive('promoci') ? 'nav-active' : '' %>">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
        Promotions
      </a>
      <a href="/admin/orders" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gray-500 transition-colors <%= isActive('pedido') ? 'nav-active' : '' %>">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Orders
      </a>

      <div class="border-t border-gray-100 my-3"></div>

      <a href="/" target="_blank" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-gray-400 transition-colors">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        Ver tienda
      </a>
    </nav>

    <!-- User profile -->
    <div class="px-4 py-4 border-t border-gray-100 flex items-center gap-3">
      <div class="w-9 h-9 rounded-full bg-boutique-pink flex items-center justify-center text-white font-semibold text-sm flex-shrink-0">
        <%= (user?.name || 'A').charAt(0).toUpperCase() %>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-medium text-gray-900 truncate"><%= user?.name?.split(' ').slice(0,2).join(' ') || 'Admin' %></p>
        <form action="/auth/logout" method="POST">
          <button type="submit" class="text-[10px] text-gray-400 hover:text-boutique-rose uppercase tracking-wider transition-colors">Log out</button>
        </form>
      </div>
    </div>
  </aside>

  <!-- ── MAIN ── -->
  <div class="flex-1 flex flex-col overflow-hidden">

    <!-- Top header -->
    <header class="bg-white border-b border-gray-100 px-6 py-3.5 flex items-center justify-between flex-shrink-0">
      <div class="relative w-72">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input type="text" placeholder="Buscar..." class="w-full pl-9 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700 focus:outline-none focus:border-boutique-pink focus:ring-1 focus:ring-boutique-pink/30 placeholder-gray-400">
      </div>
      <div class="flex items-center gap-4">
        <!-- Bell -->
        <button class="relative text-gray-400 hover:text-gray-700 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        </button>
        <!-- Settings -->
        <button class="text-gray-400 hover:text-gray-700 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </button>
        <!-- User chip -->
        <div class="flex items-center gap-2 pl-4 border-l border-gray-100">
          <span class="text-sm text-gray-700 font-medium">Jhoana Rosales Boutique</span>
          <div class="w-8 h-8 rounded-full bg-boutique-pink flex items-center justify-center text-white font-semibold text-xs">
            <%= (user?.name || 'A').charAt(0).toUpperCase() %>
          </div>
        </div>
      </div>
    </header>

    <!-- Flash messages -->
    <% if (success && success.length) { %>
      <div class="mx-6 mt-4 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg text-sm flex items-center gap-2">
        <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <%= success %>
      </div>
    <% } %>
    <% if (error && error.length) { %>
      <div class="mx-6 mt-4 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm flex items-center gap-2">
        <svg class="w-4 h-4 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
        <%= error %>
      </div>
    <% } %>

    <!-- Page content -->
    <div class="flex-1 overflow-auto p-6">
      <%- body %>
    </div>
  </div>
</div>

<script src="/js/admin/dashboard.js"></script>
</body>
</html>
