{
  "name": "jhoana-rosales-boutique",
  "version": "1.0.0",
  "description": "E-commerce profesional para Jhoana Rosales Boutique - ropa femenina",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "build:css:prod": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "alpinejs": "^3.13.5",
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "csrf-csrf": "^4.0.3",
    "csurf": "^1.11.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "express-mysql-session": "^3.0.0",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.9.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0",
    "tailwindcss": "^3.4.1"
  }
}
