generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Users ──────────────────────────────────────────────────────
model User {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(100)
  email           String    @unique @db.VarChar(150)
  password        String    @db.VarChar(255)
  role            String    @default("client") @db.VarChar(20)
  phone           String?   @db.VarChar(20)
  city            String?   @db.VarChar(100)
  address         String?   @db.VarChar(255)
  loyaltyPoints   Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orders          Order[]
  loyaltyLedger   LoyaltyLedger[]
  cart            Cart?

  @@index([email])
  @@map("users")
}

// ── Products ───────────────────────────────────────────────────
model Product {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(200)
  description     String?   @db.Text
  category        String    @db.VarChar(50)
  basePrice       Decimal   @db.Decimal(12, 2)
  imageUrl        String?   @db.VarChar(500)
  images          String?   @db.Text
  isFeatured      Boolean   @default(false)
  isActive        Boolean   @default(true)
  slug            String    @unique @db.VarChar(250)
  totalSold       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  variants        ProductVariant[]
  promotions      PromotionProduct[]
  orderItems      OrderItem[]
  cartItems       CartItem[]

  @@index([category])
  @@index([isActive, isFeatured])
  @@index([slug])
  @@map("products")
}

// ── Product Variants (talla + stock) ──────────────────────────
model ProductVariant {
  id              Int       @id @default(autoincrement())
  productId       Int
  size            String    @db.VarChar(10)
  stock           Int       @default(0)
  extraPrice      Decimal   @default(0) @db.Decimal(12, 2)
  sku             String?   @unique @db.VarChar(100)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@unique([productId, size])
  @@index([productId])
  @@map("product_variants")
}

// ── Promotions ─────────────────────────────────────────────────
model Promotion {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(200)
  code            String?   @unique @db.VarChar(50)
  type            String    @db.VarChar(30)   // percentage | fixed_amount | free_shipping
  value           Decimal   @db.Decimal(12, 2)
  minOrderAmount  Decimal   @default(0) @db.Decimal(12, 2)
  maxUses         Int?
  usedCount       Int       @default(0)
  startsAt        DateTime
  endsAt          DateTime
  isActive        Boolean   @default(true)
  appliesTo       String    @default("all") @db.VarChar(20)  // all | category | product
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  products        PromotionProduct[]
  orders          Order[]

  @@index([code])
  @@index([isActive, startsAt, endsAt])
  @@map("promotions")
}

model PromotionProduct {
  promotionId     Int
  productId       Int
  promotion       Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
  @@map("promotion_products")
}

// ── Cart ───────────────────────────────────────────────────────
model Cart {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           CartItem[]

  @@map("carts")
}

model CartItem {
  id              Int       @id @default(autoincrement())
  cartId          Int
  productId       Int
  variantId       Int
  quantity        Int       @default(1)
  unitPrice       Decimal   @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())

  cart            Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id])
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// ── Orders ─────────────────────────────────────────────────────
model Order {
  id              Int       @id @default(autoincrement())
  userId          Int?
  status          String    @default("pending_whatsapp_confirmation") @db.VarChar(50)
  paymentStatus   String    @default("pending") @db.VarChar(30)
  paymentMethod   String    @default("whatsapp") @db.VarChar(50)
  subtotal        Decimal   @db.Decimal(12, 2)
  discountAmount  Decimal   @default(0) @db.Decimal(12, 2)
  total           Decimal   @db.Decimal(12, 2)
  promotionId     Int?
  pointsUsed      Int       @default(0)
  pointsEarned    Int       @default(0)
  shippingName    String    @db.VarChar(150)
  shippingEmail   String    @db.VarChar(150)
  shippingPhone   String    @db.VarChar(20)
  shippingAddress String    @db.VarChar(300)
  shippingCity    String    @db.VarChar(100)
  shippingNotes   String?   @db.Text
  confirmToken    String?   @unique @db.VarChar(100)
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User?     @relation(fields: [userId], references: [id])
  promotion       Promotion? @relation(fields: [promotionId], references: [id])
  items           OrderItem[]
  loyaltyLedger   LoyaltyLedger[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id              Int       @id @default(autoincrement())
  orderId         Int
  productId       Int
  variantId       Int
  productName     String    @db.VarChar(200)
  size            String    @db.VarChar(10)
  quantity        Int
  unitPrice       Decimal   @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())

  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id])
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ── Loyalty Ledger ─────────────────────────────────────────────
model LoyaltyLedger {
  id              Int       @id @default(autoincrement())
  userId          Int
  orderId         Int?
  type            String    @db.VarChar(20)    // earned | redeemed | adjusted
  points          Int
  description     String    @db.VarChar(255)
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  order           Order?    @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@map("loyalty_ledger")
}
